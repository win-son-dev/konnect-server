root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,slnx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# === Language conventions ===
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
csharp_prefer_simple_using_statement = true:suggestion
csharp_prefer_braces = true:warning
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_top_level_statements = true:suggestion
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors = false:suggestion

# var preferences — allowed everywhere; the meaningful-naming rule covers
# readability, so we don't double-enforce explicit types. (Setting these to
# `:silent` keeps the IDE quiet but does not fail the build, which matters
# because TreatWarningsAsErrors is on.)
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = true:silent

# Nullable / pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:warning

# Ordering
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# === Naming conventions (meaningful names) ===
# Banned abbreviation prefixes/suffixes are enforced by review rather than
# analyzers; analyzers below catch the obvious style violations.

# Interfaces must start with I
dotnet_naming_rule.interfaces_must_start_with_i.severity = warning
dotnet_naming_rule.interfaces_must_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_start_with_i.style = i_prefixed_pascal
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *
dotnet_naming_style.i_prefixed_pascal.required_prefix = I
dotnet_naming_style.i_prefixed_pascal.capitalization = pascal_case

# Types use PascalCase
dotnet_naming_rule.types_pascal.severity = warning
dotnet_naming_rule.types_pascal.symbols = type_kinds
dotnet_naming_rule.types_pascal.style = pascal
dotnet_naming_symbols.type_kinds.applicable_kinds = class,struct,enum,delegate
dotnet_naming_symbols.type_kinds.applicable_accessibilities = *
dotnet_naming_style.pascal.capitalization = pascal_case

# Public members use PascalCase
dotnet_naming_rule.public_members_pascal.severity = warning
dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal
dotnet_naming_symbols.public_members.applicable_kinds = property,method,field,event
dotnet_naming_symbols.public_members.applicable_accessibilities = public,protected,protected_internal,internal

# Private/local fields use camelCase, private const PascalCase
dotnet_naming_rule.private_fields_camel.severity = warning
dotnet_naming_rule.private_fields_camel.symbols = private_fields
dotnet_naming_rule.private_fields_camel.style = camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private,private_protected
dotnet_naming_symbols.private_fields.required_modifiers =
dotnet_naming_style.camel.capitalization = camel_case

dotnet_naming_rule.private_const_pascal.severity = warning
dotnet_naming_rule.private_const_pascal.symbols = private_const_fields
dotnet_naming_rule.private_const_pascal.style = pascal
dotnet_naming_symbols.private_const_fields.applicable_kinds = field
dotnet_naming_symbols.private_const_fields.applicable_accessibilities = private,private_protected
dotnet_naming_symbols.private_const_fields.required_modifiers = const

# Parameters and locals use camelCase
dotnet_naming_rule.parameters_camel.severity = warning
dotnet_naming_rule.parameters_camel.symbols = parameters
dotnet_naming_rule.parameters_camel.style = camel
dotnet_naming_symbols.parameters.applicable_kinds = parameter,local

# === Diagnostic severity tweaks ===
# Async methods should end with Async
dotnet_diagnostic.VSTHRD200.severity = warning
# Disposable members must be disposed
dotnet_diagnostic.CA2000.severity = warning
# Don't use empty catch blocks
dotnet_diagnostic.CA1031.severity = warning
# Use Span<T> over arrays where possible — informational only
dotnet_diagnostic.CA1860.severity = suggestion
# XML doc not required (we don't ship doc files)
dotnet_diagnostic.CS1591.severity = none
